# Cordova platform builds (generated — never commit)
/platforms/

# Cordova plugins (restored via cordova prepare)
/plugins/

# Vite build output (regenerated by npm run build)
/www/

# Node modules
/node_modules/
/src/node_modules/

# Vite cache
/.vite/
/src/.vite/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.user

# Android signing
*.keystore
*.jks
*.p12

# iOS
*.xcworkspace/xcuserdata
*.xcodeproj/xcuserdata
DerivedData/

# Env / secrets — NEVER commit API keys
.env
.env.local
.env.example
.env.production

# txt notes*.txt
*.txt

